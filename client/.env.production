# Replace `<YOUR_GCP_VM_IP>` with the public IP assigned to your Google Cloud VM.
# When testing locally with preview, you can use real values here.
# When deploying to Vercel, it is recommended to add these variables directly in the Vercel Dashboard Settings instead.

VITE_NAKAMA_HOST=<YOUR_GCP_VM_IP>
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_USE_SSL=false
